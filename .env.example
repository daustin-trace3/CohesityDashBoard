# 32-byte hex key for AES-256-GCM credential encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# Helios API key (used when connecting via Helios)
HELIOS_API_KEY=your_helios_api_key_here

# Dashboard API key — set a strong random value (generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))")
DASHBOARD_API_KEY=your_dashboard_api_key_here

PORT=3001
